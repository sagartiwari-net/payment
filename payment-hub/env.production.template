# Copy this file to .env on VPS (File Manager or SSH)
# cp env.production.template .env
# Then fill PHONEPE_SALT_KEY and DB_PASSWORD — do NOT commit .env to GitHub

APP_ENV=production
APP_PORT=8080
APP_URL=https://buyahref.com

# MySQL (VPS — phpMyAdmin)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=paymentsystem
DB_USER=paymentsystem
DB_PASSWORD=YOUR_DB_PASSWORD_HERE

# Redis (optional for Phase 2+, leave as-is if Redis not installed yet)
REDIS_URL=redis://127.0.0.1:6379

# PhonePe (buyahref.com — production)
PHONEPE_MERCHANT_ID=BUYAONLINE
PHONEPE_SALT_KEY=YOUR_SALT_KEY_HERE
PHONEPE_SALT_INDEX=1
PHONEPE_ENV=PRODUCTION

# Security
JWT_SECRET=change_to_random_64_char_string

LOG_LEVEL=info
